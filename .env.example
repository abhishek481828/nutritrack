# ─── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend URL (used for CORS in development)
# In production (same-origin deploy), this can be omitted
CLIENT_URL=http://localhost:5173
# Comma-separated allowed origins for deployed frontend(s)
CORS_ORIGIN=https://your-frontend.vercel.app
# Set true only if the backend server should also serve a built client
SERVE_CLIENT=false

# ─── MongoDB ───────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/nutritrack
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/nutritrack
MONGO_URI=mongodb://localhost:27017/nutritrack

# ─── JWT ───────────────────────────────────────────────────────────
# Use a long, random string in production
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Cloudinary ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Spoonacular ───────────────────────────────────────────────────
SPOONACULAR_API_KEY=your_spoonacular_key
