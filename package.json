{
  "name": "nutritrack",
  "version": "1.0.0",
  "description": "AI-powered full-stack nutrition tracking application",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=production node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm install && npm run build",
    "postinstall": "cd client && npm install",
    "lint": "cd client && npm run lint",
    "test": "node --test tests/**/*.test.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.2",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.3.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "pdfkit": "^0.18.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.0"
  }
}
